generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Unidade {
  id             Int             @id @default(autoincrement())
  nome           String
  createdAt      DateTime        @default(now())

  usuarios       Usuario[]
  aulas          Aula[]
  diarias        Diaria[]
  configuracoes  Configuracao[]
  historicos     Historico[]
  contratosMeta  ContratoMeta[]
  configuracoesMeta ConfiguracaoMeta[]
  metasPessoais     MetaPessoal[]
}

model Usuario {
  id        Int      @id @default(autoincrement())
  nome      String
  email     String   @unique
  senha     String
  cargo     String   @default("ADMIN")

  pinMetas  String?
  fotoUrl   String?
  temaNome  String?  @default("AZUL")
  temaCor   String?  @default("#1e3a8a")

  unidadeId Int?
  unidade   Unidade? @relation(fields: [unidadeId], references: [id])

  createdAt DateTime @default(now())
}

model Aula {
  id                 Int      @id @default(autoincrement())
  nomeAluno          String
  telefone           String
  data               String
  horario            String
  modalidade         String
  status             String   @default("AGENDADA")
  observacoes        String?
  colaboradora       String

  veio               Boolean  @default(false)
  faltou             Boolean  @default(false)
  remarcou           Boolean  @default(false)
  cancelou           Boolean  @default(false)
  posAulaRealizado   Boolean  @default(false)
  vendaEfetivada     Boolean  @default(false)
  codigoMatricula    String?

  planoFechado       String?
  vendedora          String?
  dataConversao      String?
  tipoAluno          String?  @default("NOVO")

  criadoPorId        Int?
  criadoPorNome      String?
  alteradoPorId      Int?
  alteradoPorNome    String?
  atualizadoEm       DateTime?

  unidadeId          Int?
  unidade            Unidade? @relation(fields: [unidadeId], references: [id])

  createdAt          DateTime @default(now())
}

model Diaria {
  id               Int      @id @default(autoincrement())
  nome             String
  telefone         String
  cpf              String
  dataInicio       String
  dataFinal        String
  quantidadeDias   Int
  observacoes      String?
  colaboradora     String?

  status           String   @default("ATIVA")
  tipoDiaria       String   @default("PAGA")

  criadoPorId      Int?
  criadoPorNome    String?
  alteradoPorId    Int?
  alteradoPorNome  String?
  atualizadoEm     DateTime?

  unidadeId        Int?
  unidade          Unidade? @relation(fields: [unidadeId], references: [id])

  createdAt        DateTime @default(now())
}

model Configuracao {
  id             Int      @id @default(autoincrement())
  nomeAcademia  String
  telefone      String
  endereco      String
  metaMensal    Int
  corSistema    String
  logo          String?

  mensagemConfirmacao     String?
  mensagemLembrete        String?
  mensagemPosAula         String?
  mensagemNaoCompareceu   String?
  mensagemCancelou        String?
  mensagemDiaria          String?

  unidadeId     Int?
  unidade       Unidade? @relation(fields: [unidadeId], references: [id])

  createdAt     DateTime @default(now())
}

model Historico {
  id              Int      @id @default(autoincrement())

  usuarioId       Int?
  usuarioNome     String?
  usuarioCargo    String?

  acao            String
  tela            String
  registroId      Int?
  registroNome    String?

  descricao       String?
  dadosAntes      String?
  dadosDepois     String?

  unidadeId       Int?
  unidade         Unidade? @relation(fields: [unidadeId], references: [id])

  createdAt       DateTime @default(now())
}

model ContratoMeta {
  id                    Int      @id @default(autoincrement())

  matricula             String?
  nomeAluno             String
  vendedora             String

  plano                 String
  tipoContrato          String
  permanencia           String   @default("MENSAL")
  dataVenda             String

  valorPrimeiraParcela  Float?

  convenio              Boolean  @default(false)
  nomeConvenio          String?

  contratoDividido      Boolean  @default(false)
  quantidadeMeios       Int      @default(0)
  divididoCom           String?

  observacao            String?

  criadoPorId           Int?
  criadoPorNome         String?
  alteradoPorId         Int?
  alteradoPorNome       String?
  atualizadoEm          DateTime?

  unidadeId             Int?
  unidade               Unidade? @relation(fields: [unidadeId], references: [id])

  createdAt             DateTime @default(now())
}

model ConfiguracaoMeta {
  id          Int      @id @default(autoincrement())
  mes         String   @default("2026-06")

  meta1Qtd    Int      @default(30)
  meta1Valor  Float    @default(300)

  meta2Qtd    Int      @default(40)
  meta2Valor  Float    @default(500)

  meta3Qtd    Int      @default(50)
  meta3Valor  Float    @default(800)

  meta4Qtd    Int      @default(60)
  meta4Valor  Float    @default(1200)

  mensagemMotivacional String?
  mensagemCrista       String?

  unidadeId   Int?
  unidade     Unidade? @relation(fields: [unidadeId], references: [id])

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  metaEmpresa Int @default(60)

  campanhaTitulo String?
  campanhaPremio String?
  campanhaRegra String?
  campanhaUnidade String?
campanhaProgresso Int @default(0)
campanhaObjetivo Int @default(2)
campanhaAtiva Boolean @default(true)
campanhaFuncionarias String?

comunicado1Titulo String?
comunicado1Mensagem String?
comunicado2Titulo String?
comunicado2Mensagem String?
comunicado3Titulo String?
comunicado3Mensagem String?

lancamentoTitulo String?
lancamentoMensagem String?
}

model MetaPessoal {
  id          Int      @id @default(autoincrement())

  usuarioId   Int?
  usuarioNome String

  mes         String
  meta        Int      @default(40)

  unidadeId   Int?
  unidade     Unidade? @relation(fields: [unidadeId], references: [id])

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
