generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Unidade {
  id             Int             @id @default(autoincrement())
  nome           String
  createdAt      DateTime        @default(now())

  usuarios       Usuario[]
  aulas          Aula[]
  diarias        Diaria[]
  configuracoes  Configuracao[]
  historicos     Historico[]
}

model Usuario {
  id        Int      @id @default(autoincrement())
  nome      String
  email     String   @unique
  senha     String
  cargo     String   @default("ADMIN")

  unidadeId Int?
  unidade   Unidade? @relation(fields: [unidadeId], references: [id])

  createdAt DateTime @default(now())
}

model Aula {
  id                 Int      @id @default(autoincrement())
  nomeAluno          String
  telefone           String
  data               String
  horario            String
  modalidade         String
  status             String   @default("AGENDADA")
  observacoes        String?
  colaboradora       String

  veio               Boolean  @default(false)
  faltou             Boolean  @default(false)
  remarcou           Boolean  @default(false)
  posAulaRealizado   Boolean  @default(false)
  vendaEfetivada     Boolean  @default(false)
  codigoMatricula    String?

  planoFechado       String?
  vendedora          String?
  dataConversao      String?
  tipoAluno          String?  @default("NOVO")

  criadoPorId        Int?
  criadoPorNome      String?
  alteradoPorId      Int?
  alteradoPorNome    String?
  atualizadoEm       DateTime?

  unidadeId          Int?
  unidade            Unidade? @relation(fields: [unidadeId], references: [id])

  createdAt          DateTime @default(now())
}

model Diaria {
  id               Int      @id @default(autoincrement())
  nome             String
  telefone         String
  cpf              String
  dataInicio       String
  dataFinal        String
  quantidadeDias   Int
  observacoes      String?
  colaboradora     String?

  status           String   @default("ATIVA")
  tipoDiaria       String   @default("PAGA")

  criadoPorId      Int?
  criadoPorNome    String?
  alteradoPorId    Int?
  alteradoPorNome  String?
  atualizadoEm     DateTime?

  unidadeId        Int?
  unidade          Unidade? @relation(fields: [unidadeId], references: [id])

  createdAt        DateTime @default(now())
}

model Configuracao {
  id             Int      @id @default(autoincrement())
  nomeAcademia  String
  telefone      String
  endereco      String
  metaMensal    Int
  corSistema    String
  logo          String?

  mensagemConfirmacao     String?
  mensagemLembrete        String?
  mensagemPosAula         String?
  mensagemNaoCompareceu   String?
  mensagemDiaria          String?

  unidadeId     Int?
  unidade       Unidade? @relation(fields: [unidadeId], references: [id])

  createdAt     DateTime @default(now())
}

model Historico {
  id              Int      @id @default(autoincrement())

  usuarioId       Int?
  usuarioNome     String?
  usuarioCargo    String?

  acao            String
  tela            String
  registroId      Int?
  registroNome    String?

  descricao       String?
  dadosAntes      String?
  dadosDepois     String?

  unidadeId       Int?
  unidade         Unidade? @relation(fields: [unidadeId], references: [id])

  createdAt       DateTime @default(now())
}